# Required — LLM access via OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...

# Optional — image generation via Replicate Seedream 4.5 (https://replicate.com/account/api-tokens)
REPLICATE_API_TOKEN=r8_...

# Optional — audiobook TTS via OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Set to "true" for hosted deployments where users provide their own API keys via the UI
NEXT_PUBLIC_USER_API_KEYS=false
